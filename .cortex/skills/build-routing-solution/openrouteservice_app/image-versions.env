# Single source of truth for all SPCS image tags.
# deploy.sh bumps these; check_image_versions.sh validates
# all other files match. The skill agent reads this at build time.
OPENROUTESERVICE_TAG=v9.0.0
DOWNLOADER_TAG=v0.0.3
ROUTING_REVERSE_PROXY_TAG=v1.1.0
VROOM_DOCKER_TAG=v1.0.4
ORS_CONTROL_APP_TAG=v1.1.5

# Upstream base image versions (pinned to avoid pulling broken releases).
# Bump procedure: test locally with `docker run <image>:<new_tag>`, then
# rebuild and push the corresponding SPCS image.
OPENROUTESERVICE_BASE_TAG=v9.0.0
VROOM_BASE_TAG=v1.14.0
