# Local development environment variables.
# Copy to .env and fill in your values.
# In SPCS these are injected automatically by Snowflake — do not set them in production.

# Snowflake CLI connection name (used for local dev when IS_SPCS=false)
SNOWFLAKE_CONNECTION=

# Snowflake database (defaults to OPENROUTESERVICE_APP if unset)
SNOWFLAKE_DATABASE=OPENROUTESERVICE_APP

# Snowflake warehouse (defaults to ROUTING_ANALYTICS if unset)
SNOWFLAKE_WAREHOUSE=ROUTING_ANALYTICS

# SPCS-injected host — leave blank for local dev (IS_SPCS will be false when this is empty)
SNOWFLAKE_HOST=
